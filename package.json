{
  "name": "mfds-drug-dashboard",
  "version": "0.1.0",
  "private": true,
  "description": "MFDS drug detail crawler and searchable Vercel dashboard",
  "scripts": {
    "serve": "node scripts/local-server.mjs",
    "scrape:samples": "node scripts/scrape-mfds.mjs --itemSeq 202601126,201404452,202204314 --out data/drugs.sample.json",
    "scrape:page1": "node scripts/scrape-mfds.mjs --pages 1-1 --limit 10 --out data/drugs.json",
    "changes:update": "node scripts/update-change-log.mjs --category human,vet",
    "changes:update:all": "node scripts/update-change-log.mjs --category all"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.0.0"
  }
}
